classDiagram
    class Usuario {
        +id
        +nome
        +email
    }

    class Pergunta {
        +id
        +titulo
        +conteudo
        +dataCriacao
        +totalVotos
    }

    class Resposta {
        +id
        +conteudo
        +dataCriacao
    }

    class Voto {
        +id
        +tipo
    }

    class Tag {
        +id
        +nome
    }

    Usuario "1" --> "0..*" Pergunta : cria
    Usuario "1" --> "0..*" Resposta : escreve
    Pergunta "1" --> "0..*" Resposta : possui
    Usuario "1" --> "0..*" Voto : realiza
    Pergunta "1" --> "0..*" Voto : recebe
    Pergunta "0..*" --> "0..*" Tag : possui
sequenceDiagram
    actor Usuario
    participant Frontend
    participant API
    participant Banco

    Usuario->>Frontend: Digita palavra-chave
    Usuario->>Frontend: Confirma busca
    Frontend->>API: GET /perguntas?busca=palavra
    API->>Banco: Consulta perguntas por título ou conteúdo
    Banco-->>API: Retorna perguntas encontradas
    API-->>Frontend: Retorna lista de perguntas
    Frontend-->>Usuario: Exibe resultados da busca

flowchart TD
    A([Início]) --> B[Usuário acessa lista de perguntas]
    B --> C[Usuário digita palavra-chave]
    C --> D[Usuário confirma busca]
    D --> E[Sistema consulta perguntas no banco]
    E --> F{Encontrou perguntas?}
    F -->|Sim| G[Exibe perguntas encontradas]
    F -->|Não| H[Exibe mensagem de nenhuma pergunta encontrada]
    G --> I([Fim])
    H --> I([Fim])

stateDiagram-v2
    [*] --> Criada
    Criada --> Publicada: pergunta salva
    Publicada --> Editada: usuário edita pergunta
    Editada --> Publicada: alteração salva
    Publicada --> Respondida: recebe resposta
    Respondida --> Encerrada: dúvida resolvida
    Publicada --> Removida: pergunta excluída
    Respondida --> Removida: pergunta excluída
    Encerrada --> [*]
    Removida --> [*]
